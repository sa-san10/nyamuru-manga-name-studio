---
import Layout from '../layouts/Layout.astro';

const releases = [
  {
    version: '1.0.1',
    code: 2,
    date: '2026-07-24',
    title: '紙面編集オーバーホール',
    changes: [
      '紙面ズーム：スマホの二本指ピンチで拡大縮小・視点移動、PCはCtrl+ホイール、右下にズームボタン。拡大すると文字も一緒に拡大',
      'コマ操作：多角形コマの頂点をドラッグで個別編集、PANELラベルをドラッグでコマ移動、ハンドルの大型化と当たり判定拡大',
      'コマ選択の表示を塗りつぶしから辺のハイライトに変更、PANELラベルは常にコマ左上の外側に',
      '多角形コマで枠線が切れる問題を修正（枠線をSVG描画に一新）',
      'フキダシ：文字サイズを2倍にし、はみ出す場合は自動縮小。文字背景に半透明の白マットを追加',
      'フキダシの形状をボックスいっぱいに描画（余白除去）、whisperを点線に、手描き文字に余白を追加',
      '人物/オブジェクトボックス：枠を太めの実線に、名前を2倍サイズ+収まらない場合は自動縮小',
      'コマ割りパターンEの中段に生じていた隙間を修正（生成プロンプトの座標も同期）',
      '案内ポップアップ：サンプル漫画をタップで全画面表示（タップでページ送り）、「創作パートナーのAIに聞いてみる」コピペ欄を新設',
      '使い方ページ：先頭に「AIに聞いてみる」欄、フロー図に「作業の流れ」タイトルを追加',
      'GitHub Pages版：読み込みページにOGP・favicon・サイト説明メタデータを追加',
    ],
  },
  {
    version: '1.0.0',
    code: 1,
    date: '2026-07-22',
    title: '初回リリース',
    changes: [
      'ネーム編集：コマ割り・人物・フキダシをドラッグで配置調整、コマ割りパターン適用、アンドゥ／リドゥ',
      '作品情報・舞台設定・登場人物・素材の各エディタ',
      'OMNY編集：YAMLの直接編集・整形・反映',
      'NDM検査：Nyamuru Data Model v10のルールに沿った自動チェック',
      '使い方ガイド：LLM→調整→画像生成AIの3ステップワークフロー案内と初回案内ポップアップ',
      '漫画ネーム生成プロンプト・エージェント生成ワークフロー・NDM仕様の閲覧とダウンロード',
      '公式マスコット「にゃむるたん」ページ（キャラクター設定・立ち絵素材、CC BY 4.0）',
      'サンプル漫画『押しかけ妖精にゃむるたん』を収録',
      'PWA対応：オフライン動作・編集内容の端末内自動保存',
      'スタンドアロン版（単一HTMLファイル）の同梱配信とダウンロードボタン',
      'URLの ?tab= 指定で任意のタブを直接開けるディープリンク',
    ],
  },
];
---

<Layout title="バージョン履歴 | Nyamuru🐱Manga Name Studio" description="Nyamuru🐱Manga Name Studioのバージョン履歴・更新内容">
  <main class="changelog-page">
    <nav><a href="/">← アプリへ戻る</a></nav>
    <header>
      <span>VERSION HISTORY</span>
      <h1>バージョン履歴</h1>
      <p><strong>Nyamuru🐱Manga Name Studio</strong>のリリースごとの更新内容です。</p>
    </header>

    {releases.map((release) => (
      <section>
        <div class="release-head">
          <h2>v{release.version}</h2>
          <span class="release-title">{release.title}</span>
          <span class="release-code">バージョンコード {release.code}</span>
          <time datetime={release.date}>{release.date}</time>
        </div>
        <ul>
          {release.changes.map((change) => <li>{change}</li>)}
        </ul>
      </section>
    ))}
  </main>
</Layout>

<style>
  :global(body) { overflow: auto; }
  .changelog-page { width: min(860px, calc(100% - 32px)); margin: 0 auto; padding: 32px 0 64px; }
  nav { margin-bottom: 32px; }
  a { color: #d94661; font-weight: 700; text-decoration: none; }
  a:hover { text-decoration: underline; }
  header { padding: 30px; border: 1px solid #f0d9df; border-radius: 18px; background: linear-gradient(135deg, #fff0f3, #f0f8ff); }
  header span { color: #e64f68; font: 800 10px/1 monospace; letter-spacing: .16em; }
  h1 { margin: 10px 0 12px; font-size: clamp(26px, 5vw, 42px); }
  p { margin: 0; color: #606572; line-height: 1.85; }
  section { margin-top: 20px; padding: 24px; border: 1px solid #f0e5e8; border-radius: 14px; background: rgba(255,255,255,.96); }
  .release-head { display: flex; align-items: baseline; flex-wrap: wrap; gap: 10px; margin-bottom: 10px; }
  h2 { margin: 0; font-size: 22px; color: #d94661; }
  .release-title { color: #47434c; font-size: 14px; font-weight: 800; }
  .release-code { padding: 3px 8px; border: 1px solid #f0d9df; border-radius: 999px; color: #a08a92; font: 700 10px/1 ui-monospace, monospace; }
  time { margin-left: auto; color: #7b8190; font: 700 11px/1 ui-monospace, monospace; }
  ul { margin: 0; padding-left: 22px; }
  li { margin: 6px 0; color: #5e5a64; line-height: 1.75; }
  @media (max-width: 560px) {
    .changelog-page { width: min(100% - 20px, 860px); padding-top: 20px; }
    header, section { padding: 18px; }
  }
</style>
